# GSRS RAG Gateway - Environment Configuration

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database URL - scheme determines backend automatically:
# - PostgreSQL: postgresql://user:pass@host:port/dbname
# - ChromaDB: chroma://./chroma_data/chunks

# For ChromaDB (Development/Testing - Default):
DATABASE_URL=chroma://./chroma_data/chunks

# For PostgreSQL (Production - uncomment and set):
# DATABASE_URL=postgresql://gsrs:your_secure_password@localhost:5432/gsrs_rag

# =============================================================================
# EMBEDDING API CONFIGURATION
# =============================================================================
# Works with OpenAI, Azure OpenAI, Ollama, and OpenAI-compatible APIs

# OpenAI (Production):
EMBEDDING_API_KEY=sk-your-api-key-here
EMBEDDING_URL=https://api.openai.com/v1/embeddings
EMBEDDING_VERIFY_SSL=true

# Azure OpenAI (uncomment and configure for Azure):
# EMBEDDING_API_KEY=your-azure-key
# EMBEDDING_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment/embeddings?api-version=2024-02-01
# EMBEDDING_VERIFY_SSL=false

# Ollama (Local/Development - uncomment for local embeddings):
# EMBEDDING_API_KEY=ollama
# EMBEDDING_URL=http://host.docker.internal:11434/api/embed

# =============================================================================
# EMBEDDING MODEL CONFIGURATION
# =============================================================================
# OpenAI Models:
#   - text-embedding-3-small (1536 dim, recommended)
#   - text-embedding-3-large (3072 dim, highest quality)
#   - text-embedding-ada-002 (1536 dim, legacy)

# Ollama Models:
#   - nomic-embed-text-v2-moe (768 dim, lightweight)
#   - mxbai-embed-large (1024 dim, high quality)
#   - qwen3-embedding:latest (2000 dim, high quality)
#   - all-minilm (384 dim, smallest)

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# =============================================================================
# SUBSTANCE CHUNKER CONFIGURATION
# =============================================================================
# SubstanceChunker splits GSRS substance JSON documents into searchable chunks.
# Fine-tuning is available via ChunkerConfig (see gsrs.services.ai.ChunkerConfig).

# Batch size for name processing (default: 30)
CHUNKER_NAME_BATCH_SIZE=30

# Emit individual name chunks instead of batching (default: false)
# CHUNKER_EMIT_ATOMIC_NAME_CHUNKS=false

# Emit nucleic acid/protein sequence segments (default: false)
# CHUNKER_EMIT_SEQUENCE_SEGMENTS=false

# Maximum character length of a sequence segment (default: 300)
CHUNKER_MAX_SEQUENCE_SEGMENT_LEN=300

# Include the full sequence text in the chunk (default: false)
# CHUNKER_EMIT_FULL_SEQUENCE_IN_TEXT=false

# Include administrative validation notes (default: false)
# CHUNKER_INCLUDE_ADMIN_VALIDATION_NOTES=false

# Include a reference index chunk listing all identifiers (default: true)
CHUNKER_INCLUDE_REFERENCE_INDEX_CHUNK=true

# Include a classification summary chunk (default: true)
CHUNKER_INCLUDE_CLASSIFICATION_CHUNK=true

# Include grouped relationship summaries (default: true)
CHUNKER_INCLUDE_GROUPED_RELATIONSHIP_SUMMARIES=true

# =============================================================================
# AUTHENTICATION CONFIGURATION (HTTP Basic Auth)
# =============================================================================
# Change these in production!
API_USERNAME=admin
API_PASSWORD=admin123

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# Vector Search Configuration
DEFAULT_TOP_K=5

# =============================================================================
# LLM API CONFIGURATION (for /ask endpoint - query rewrite, answering, etc.)
# =============================================================================
# Works with OpenAI, Azure OpenAI, Ollama, and OpenAI-compatible APIs
# Leave LLM_API_KEY empty to disable LLM-based answering (falls back to template answers)

# OpenAI (Production):
LLM_API_KEY=sk-your-api-key-here
LLM_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini
LLM_VERIFY_SSL=true
LLM_TIMEOUT=30

# Azure OpenAI (uncomment and configure for Azure):
# LLM_API_KEY=your-azure-key
# LLM_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2024-02-01
# LLM_MODEL=gpt-4o-mini
# LLM_VERIFY_SSL=false
# LLM_TIMEOUT=60

# Ollama (Local/Development - uncomment for local LLM):
# LLM_API_KEY=ollama
# LLM_URL=http://host.docker.internal:11434/api/chat
# LLM_MODEL=llama3.1
# LLM_VERIFY_SSL=false
# LLM_TIMEOUT=120

# =============================================================================
# MCP (Model Context Protocol) SERVER CONFIGURATION
# =============================================================================
# Transport: "streamable-http" (HTTP POST JSON-RPC on port below), "stdio" (local stdin/stdout)
MCP_TRANSPORT=streamable-http

# MCP server host and port
MCP_HOST=0.0.0.0
MCP_PORT=8000

# MCP SSL verification
# MCP_VERIFY_SSL=true

# =============================================================================
# GSRS OFFICIAL API CONFIGURATION
# =============================================================================
# Access the official GSRS REST API for fetching substances, text/structure/sequence search.
# GSRS_API_PUBLIC_ONLY: if true, all elements with non-empty "access" lists are removed.

GSRS_API_URL=https://gsrs.ncats.nih.gov/api/v1
GSRS_API_TIMEOUT=30
GSRS_API_VERIFY_SSL=true
# GSRS_API_PUBLIC_ONLY=false

# =============================================================================
# OPEN WEBUI CONFIGURATION (Optional, for Ollama integration)
# =============================================================================
# Ollama base URL (for Open WebUI)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# WebUI secret key (change in production!)
WEBUI_SECRET_KEY=gsrs_secret_key_change_me_in_production

# Enable authentication in WebUI
WEBUI_AUTH=true

