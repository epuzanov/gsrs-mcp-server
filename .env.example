# GSRS MCP Server environment configuration

# ---------------------------------------------------------------------------
# Vector database backend
# ---------------------------------------------------------------------------
# ChromaDB is the easiest local default.
DATABASE_URL=chroma://./chroma_data/chunks
# PostgreSQL + pgvector example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gsrs_mcp

# ---------------------------------------------------------------------------
# Embedding provider (required for retrieval and ingest)
# ---------------------------------------------------------------------------
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_URL=https://api.openai.com/v1/embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_VERIFY_SSL=true
EMBEDDING_TIMEOUT=30
EMBEDDING_MAX_RETRIES=2
EMBEDDING_RETRY_BACKOFF_MS=250

# Ollama example:
# EMBEDDING_API_KEY=ollama
# EMBEDDING_URL=http://host.docker.internal:11434/api/embed
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSION=768

# ---------------------------------------------------------------------------
# Optional answer-generation provider
# Leave LLM_API_KEY empty to keep the server in retrieval-only mode.
# ---------------------------------------------------------------------------
LLM_API_KEY=
LLM_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini
LLM_VERIFY_SSL=true
LLM_TIMEOUT=30
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_MS=250

# ---------------------------------------------------------------------------
# MCP server transport and auth
# ---------------------------------------------------------------------------
MCP_TRANSPORT=streamable-http
MCP_API=0.0.0.0
MCP_PORT=8000
# Deployment metadata only for the current HTTP bearer flow.
MCP_USERNAME=admin
# Bearer token value for the /mcp endpoint when using streamable HTTP.
MCP_PASSWORD=change-me

# ---------------------------------------------------------------------------
# GSRS upstream API tools (optional)
# ---------------------------------------------------------------------------
GSRS_API_URL=https://gsrs.ncats.nih.gov/api/v1
GSRS_API_TIMEOUT=30
GSRS_API_VERIFY_SSL=true
GSRS_API_MAX_RETRIES=1
GSRS_API_RETRY_BACKOFF_MS=250
GSRS_API_PUBLIC_ONLY=false

# ---------------------------------------------------------------------------
# Runtime / observability
# ---------------------------------------------------------------------------
DEFAULT_TOP_K=5
IDENTIFIER_CODE_SYSTEMS=CAS,UNII,FDA UNII,PubChem,DrugBank,ChEMBL,RXCUI,SMS_ID,SMSID,EVMPD,xEVMPD,ASK,ASKP
ANSWER_CONFIDENCE_THRESHOLD=0.35
MAX_ANSWER_EVIDENCE=5
DEBUG_MODE=false
STARTUP_VALIDATE_EXTERNAL=false

# ---------------------------------------------------------------------------
# Chunker tuning
# ---------------------------------------------------------------------------
CHUNKER_NAME_BATCH_SIZE=30
CHUNKER_MAX_SEQUENCE_SEGMENT_LEN=300
CHUNKER_INCLUDE_REFERENCE_INDEX_CHUNK=true
CHUNKER_INCLUDE_CLASSIFICATION_CHUNK=true
CHUNKER_INCLUDE_GROUPED_RELATIONSHIP_SUMMARIES=true
